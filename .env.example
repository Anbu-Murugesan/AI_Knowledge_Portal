# ============================================
# AI Intelligence Knowledge Hub
# Environment Variables Configuration
# ============================================
#
# Copy this file to .env and fill in your actual API keys:
#   cp .env.example .env
#
# Then edit .env with your actual values.
# DO NOT commit .env to version control!
# ============================================

# ============================================
# Required API Keys
# ============================================

# Groq API Key
# Required for: LLM operations, text summarization, research paper summaries
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Key
# Required for: Event discovery (hackathons, conferences, workshops)
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ============================================
# Notes
# ============================================
# - All API keys are required for full functionality
# - Without GROQ_API_KEY: Chat and research paper summarization will fail
# - Without TAVILY_API_KEY: Event discovery will fail
# - Keep your .env file secure and never commit it to version control